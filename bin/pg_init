#!/usr/bin/env python3
"""Initialize a PostgreSQL development worktree."""

import argparse
import sys
from pathlib import Path

# Add repo root to path for lib imports
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from lib.config import REPL_STREAMING_ASYNC, REPL_STREAMING_SYNC, REPL_LOGICAL
from lib.init import init_branch


def main():
    parser = argparse.ArgumentParser(
        description="Initialize a PostgreSQL development worktree"
    )
    parser.add_argument(
        "-b", dest="branch",
        help="Branch or tag to checkout (default: prompt interactively)",
    )
    parser.add_argument(
        "-B", dest="base_branch", default="master",
        help="Base branch for new branch creation (default: master)",
    )
    parser.add_argument(
        "-s", "--standby", action="append", dest="standbys",
        choices=["sync", "async", "logical"],
        help="Add a standby (repeatable). e.g. -s sync -s async",
    )
    args = parser.parse_args()

    branch = args.branch
    base_branch = args.base_branch

    # Interactive prompt if branch not provided
    if not branch:
        branch = input("Branch (default: master): ").strip() or "master"

    if not args.branch:
        user_base = input(f"Base branch (default: {base_branch}): ").strip()
        if user_base:
            base_branch = user_base

    # Convert standby shorthand to full type names
    standbys = None
    if args.standbys:
        type_map = {
            "sync": REPL_STREAMING_SYNC,
            "async": REPL_STREAMING_ASYNC,
            "logical": REPL_LOGICAL,
        }
        standbys = [{"type": type_map[s]} for s in args.standbys]

    try:
        init_branch(branch, base_branch, standbys=standbys)
    except Exception as e:
        print(f"\nError: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
