#!/usr/bin/env python3
"""Show status of PostgreSQL development worktrees."""

import argparse
import json
import sys
from pathlib import Path

# Add repo root to path for lib imports
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from lib.config import DB_PATH, PGSQL_DIR, standby_port
from lib.db import get_connection, get_standbys, init_db
from lib.operations import check_pg_running, parse_port_lock, scan_worktrees


def main():
    parser = argparse.ArgumentParser(
        description="Show status of PostgreSQL development worktrees"
    )
    parser.add_argument(
        "--json", action="store_true", dest="json_output",
        help="Output in JSON format",
    )
    args = parser.parse_args()

    init_db()
    worktrees = scan_worktrees()
    port_map = parse_port_lock()

    # Get DB statuses
    conn = get_connection()
    rows = conn.execute("SELECT name, status FROM branches").fetchall()
    conn.close()
    db_status = {row["name"]: row["status"] for row in rows}

    entries = []
    for name in worktrees:
        port = port_map.get(name)
        entry = {
            "branch": name,
            "port": port,
            "pg": check_pg_running(name),
            "status": db_status.get(name, "active"),
            "standbys": [],
        }
        sbs = get_standbys(name)
        for sb in sbs:
            idx = sb["standby_index"]
            sb_port = standby_port(port, idx) if port else None
            entry["standbys"].append({
                "index": idx,
                "type": sb["repl_type"],
                "port": sb_port,
                "pg": check_pg_running(name, idx),
            })
        entries.append(entry)

    if args.json_output:
        print(json.dumps(entries, indent=2))
        return

    if not entries:
        print("No worktrees found.")
        return

    # Table format
    name_w = max(len(e["branch"]) for e in entries)
    name_w = max(name_w, 6)  # "BRANCH" header
    # Account for standby indented names
    for e in entries:
        for sb in e["standbys"]:
            sb_label = f"  S{sb['index']} ({sb['type']})"
            name_w = max(name_w, len(sb_label))

    print(f"{'BRANCH':<{name_w}}  {'PORT':>5}  {'PG':<4}  STATUS")
    print(f"{'-' * name_w}  -----  ----  ------")
    for e in entries:
        port_str = str(e["port"]) if e["port"] else "-"
        pg_str = e["pg"] or "-"
        print(f"{e['branch']:<{name_w}}  {port_str:>5}  {pg_str:<4}  {e['status']}")
        for sb in e["standbys"]:
            sb_label = f"  S{sb['index']} ({sb['type']})"
            sb_port = str(sb["port"]) if sb["port"] else "-"
            sb_pg = sb["pg"] or "-"
            print(f"{sb_label:<{name_w}}  {sb_port:>5}  {sb_pg:<4}")


if __name__ == "__main__":
    main()
