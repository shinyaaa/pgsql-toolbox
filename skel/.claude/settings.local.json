{
  "plansDirectory": "./.claude/plans",
  "permissions": {
    "allow": [
      "Bash(./configure:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(make:*)",
      "Bash(meson:*)",
      "Bash(ninja:*)",
      "Bash(git:*)",
      "Bash(initdb:*)",
      "Bash(pg_ctl:*)",
      "Bash(pg_config:*)",
      "Bash(psql:*)",
      "Bash(perl:*)",
      "Bash(python3:*)",
      "Bash(xargs:*)",
      "Bash(export:*)",
      "Bash(PERL5LIB=:*)",
      "Bash(PATH=:*)",
      "Bash(src/tools/pgindent/pgindent:*)",
      "Bash(codex:*)",
      "Bash(curl:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(chmod:*)",
      "Bash(patch:*)",
      "Bash(gdb:*)",
      "Bash(strace:*)",
      "Bash(ulimit:*)",
      "Bash(coredumpctl debug:*)",
      "Bash(coredumpctl gdb:*)",
      "Bash(coredumpctl info:*)",
      "Bash(coredumpctl list:*)",
      "WebSearch",
      "WebFetch(domain:access.redhat.com)",
      "WebFetch(domain:docs.kernel.org)",
      "WebFetch(domain:git.postgresql.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:groups.google.com)",
      "WebFetch(domain:linux-commits-search.typesense.org)",
      "WebFetch(domain:lwn.net)",
      "WebFetch(domain:man7.org)",
      "WebFetch(domain:patchwork.kernel.org)",
      "WebFetch(domain:pgsql-hackers.postgresql.narkive.com)",
      "WebFetch(domain:postgres.ai)",
      "WebFetch(domain:postgrespro.com)",
      "WebFetch(domain:rhaas.blogspot.com)",
      "WebFetch(domain:www.highgo.ca)",
      "WebFetch(domain:www.mail-archive.com)",
      "WebFetch(domain:www.spinics.net)",
      "mcp__pgsql-ml-mcp",
      "Bash(ssh shinya@192.168.1.3:*)",
      "Bash(gh *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh *)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/gh-repo-guard.sh\""
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": [
    "pgsql-ml-mcp"
  ],
  "enableAllProjectMcpServers": true
}
